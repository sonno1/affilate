# =============================================
#  Value Content Automation — Environment Config
# =============================================

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Facebook Graph API ---
FB_PAGE_ID=your_page_id
FB_ACCESS_TOKEN=your_page_access_token

# --- RSS Sources (comma-separated) ---
RSS_URLS=https://vnexpress.net/rss/tin-moi-nhat.rss,https://feeds.feedburner.com/TechCrunch

# --- Scheduler ---
AUTO_CRAWL_INTERVAL_MINUTES=30

# --- Database (default: SQLite) ---
DATABASE_URL=sqlite:///./posts.db

# --- CORS (comma-separated frontend origins) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- GitHub Push ---
# Personal Access Token — create at https://github.com/settings/tokens
# Required scopes: repo (full) + workflow
GITHUB_USERNAME=your_github_username
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=your-repo-name
GITHUB_BRANCH=main
