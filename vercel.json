{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.py": {
      "runtime": "python3.11",
      "maxDuration": 30,
      "includeFiles": "backend/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*",      "destination": "/api/index.py" },
    { "source": "/shopee/:path*",   "destination": "/api/index.py" },
    { "source": "/shorten",         "destination": "/api/index.py" },
    { "source": "/shortlinks",      "destination": "/api/index.py" },
    { "source": "/r/:token",        "destination": "/api/index.py" },
    { "source": "/posts/:path*",    "destination": "/api/index.py" },
    { "source": "/posts",           "destination": "/api/index.py" },
    { "source": "/crawl",           "destination": "/api/index.py" },
    { "source": "/generate",        "destination": "/api/index.py" },
    { "source": "/facebook/:path*", "destination": "/api/index.py" },
    { "source": "/:path*",          "destination": "/index.html" }
  ]
}
